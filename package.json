{
  "name": "@docspace/ui-kit",
  "version": "0.0.1",
  "description": "DocSpace UI Component Library",
  "private": "true",
  "scripts": {
    "build": "node scripts/copy-locales.js && rollup -c",
    "build:watch": "rollup -c -w",
    "clean": "rm -rf dist",
    "storybook": "node scripts/copy-locales.js && storybook dev -p 6006",
    "storybook-build": "node scripts/copy-locales.js && storybook build",
    "storybook-serve": "node scripts/copy-locales.js && serve storybook-static -p 6006",
    "test": "node scripts/copy-locales.js && vitest run",
    "test:ui": "node scripts/copy-locales.js && vitest --ui",
    "test:watch": "node scripts/copy-locales.js && vitest",
    "test:coverage": "node scripts/copy-locales.js && vitest --coverage",
    "lint": "node scripts/copy-locales.js && biome lint .",
    "lint:fix": "node scripts/copy-locales.js && biome lint --write .",
    "format": "node scripts/copy-locales.js && biome check .",
    "format:fix": "node scripts/copy-locales.js && biome check --write .",
    "tsc": "node scripts/copy-locales.js && tsc",
    "prepublishOnly": "pnpm run build",
    "prepare": "node -e \"if (!process.env.CI) { try { require('child_process').execSync('git --version', {stdio: 'ignore'}); require('child_process').execSync('lefthook install', {stdio: 'inherit'}); } catch (e) { console.error('Lefthook installation skipped:', e.message); } }\""
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.3",
    "@floating-ui/dom": "1.6.13",
    "@onlyoffice/docspace-api-sdk": "file:onlyoffice-docspace-api-sdk-3.6.0.tgz",
    "@types/node": "24.10.7",
    "@types/react-text-mask": "5.4.14",
    "classnames": "^2.5.1",
    "cnbuilder": "3.1.0",
    "copy-to-clipboard": "3.3.3",
    "csvjson-json_beautifier": "5.0.4",
    "email-addresses": "5.0.0",
    "fast-deep-equal": "3.1.3",
    "framer-motion": "^12.30.0",
    "hex-rgb": "^5.0.0",
    "i18n": "^0.15.3",
    "i18next": "23.7.19",
    "lodash": "4.17.23",
    "luxon": "3.7.2",
    "react-autosize-textarea": "7.1.0",
    "react-avatar-editor": "^14.0.0",
    "react-colorful": "^5.6.1",
    "react-content-loader": "7.0.2",
    "react-countdown": "2.3.6",
    "react-device-detect": "2.2.3",
    "react-draggable": "4.4.6",
    "react-dropzone": "11.7.1",
    "react-hotkeys-hook": "^5.2.3",
    "react-i18n": "^1.0.1",
    "react-i18next": "14.0.1",
    "react-svg": "16.1.34",
    "react-text-mask": "5.5.0",
    "react-toastify": "10.0.6",
    "react-tooltip": "5.28.0",
    "react-transition-group": "4.4.5",
    "react-virtualized": "^9.22.6",
    "react-window": "1.8.10",
    "react-window-infinite-loader": "1.0.9",
    "styled-components": "5.3.11",
    "ts-pattern": "5.5.0",
    "xss": "^1.0.15",
    "zoom-level": "2.5.0"
  },
  "devDependencies": {
    "@babel/core": "7.25.8",
    "@biomejs/biome": "2.3.11",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@svgr/rollup": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "4.17.10",
    "@types/luxon": "3.7.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "4.4.11",
    "@types/react-virtualized": "^9.22.3",
    "@types/react-window": "1.8.8",
    "@types/react-window-infinite-loader": "1.0.9",
    "@types/styled-components": "5.1.34",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "@vueless/storybook-dark-mode": "^10.0.0",
    "glob": "^11.1.0",
    "jsdom": "^27.4.0",
    "lefthook": "^2.0.14",
    "postcss": "^8.4.49",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rollup": "^4.28.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.79.5",
    "serve": "^14.2.5",
    "storybook": "^10.2.8",
    "typescript": "^5.9.3",
    "vite": "^6.1.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.17"
  },
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "docspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/DocSpace-client.git",
    "directory": "libs/ui-kit"
  },
  "files": [
    "dist",
    "locales"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./components": {
      "source": "./components/index.ts",
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/esm/components/index.js",
      "require": "./dist/cjs/components/index.js"
    },
    "./components/*": {
      "source": "./components/*/index.ts",
      "types": "./dist/types/components/*/index.d.ts",
      "import": "./dist/esm/components/*/index.js",
      "require": "./dist/cjs/components/*/index.js"
    },
    "./hooks": {
      "source": "./hooks/index.ts",
      "types": "./dist/types/hooks/index.d.ts",
      "import": "./dist/esm/hooks/index.js",
      "require": "./dist/cjs/hooks/index.js"
    },
    "./hooks/*": {
      "source": "./hooks/*/index.ts",
      "types": "./dist/types/hooks/*/index.d.ts",
      "import": "./dist/esm/hooks/*/index.js",
      "require": "./dist/cjs/hooks/*/index.js"
    },
    "./providers": {
      "source": "./providers/index.ts",
      "types": "./dist/types/providers/index.d.ts",
      "import": "./dist/esm/providers/index.js",
      "require": "./dist/cjs/providers/index.js"
    },
    "./providers/*": {
      "source": "./providers/*/index.ts",
      "types": "./dist/types/providers/*/index.d.ts",
      "import": "./dist/esm/providers/*/index.js",
      "require": "./dist/cjs/providers/*/index.js"
    },
    "./utils": {
      "source": "./utils/index.ts",
      "types": "./dist/types/utils/index.d.ts",
      "import": "./dist/esm/utils/index.js",
      "require": "./dist/cjs/utils/index.js"
    },
    "./utils/*": {
      "source": "./utils/*/index.ts",
      "types": "./dist/types/utils/*/index.d.ts",
      "import": "./dist/esm/utils/*/index.js",
      "require": "./dist/cjs/utils/*/index.js"
    },
    "./context/*": {
      "source": "./context/*/index.ts",
      "types": "./dist/types/context/*/index.d.ts",
      "import": "./dist/esm/context/*/index.js",
      "require": "./dist/cjs/context/*/index.js"
    },
    "./context": {
      "source": "./context/index.ts",
      "types": "./dist/types/context/index.d.ts",
      "import": "./dist/esm/context/index.js",
      "require": "./dist/cjs/context/index.js"
    },
    "./enums": {
      "source": "./enums/index.ts",
      "types": "./dist/types/enums/index.d.ts",
      "import": "./dist/esm/enums/index.js",
      "require": "./dist/cjs/enums/index.js"
    },
    "./constants": {
      "source": "./constants/index.ts",
      "types": "./dist/types/constants/index.d.ts",
      "import": "./dist/esm/constants/index.js",
      "require": "./dist/cjs/constants/index.js"
    },
    "./types": {
      "source": "./types/index.ts",
      "types": "./dist/types/types/index.d.ts",
      "import": "./dist/esm/types/index.js",
      "require": "./dist/cjs/types/index.js"
    },
    "./errors": {
      "source": "./errors/index.ts",
      "types": "./dist/types/errors/index.d.ts",
      "import": "./dist/esm/errors/index.js",
      "require": "./dist/cjs/errors/index.js"
    }
  },
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ]
}