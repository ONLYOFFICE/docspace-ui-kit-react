{
  "name": "@docspace/ui-kit",
  "version": "0.0.1",
  "description": "DocSpace UI Component Library",
  "private": "true",
  "scripts": {
    "copy-assets": "node scripts/copy-locales.js && node scripts/copy-images.js",
    "build": "pnpm run copy-assets && rollup -c",
    "build:watch": "rollup -c -w",
    "clean": "rm -rf dist",
    "storybook": "pnpm run copy-assets && storybook dev -p 6006",
    "storybook-build": "pnpm run copy-assets && storybook build",
    "storybook-serve": "pnpm run copy-assets && serve storybook-static -p 6006",
    "test": "pnpm run copy-assets && vitest run",
    "test:ui": "pnpm run copy-assets && vitest --ui",
    "test:watch": "pnpm run copy-assets && vitest",
    "test:coverage": "pnpm run copy-assets && vitest --coverage",
    "lint": "pnpm run copy-assets && biome lint .",
    "lint:fix": "pnpm run copy-assets && biome lint --write .",
    "format": "pnpm run copy-assets && prettier --check .",
    "format:fix": "pnpm run copy-assets && prettier --write .",
    "tsc": "pnpm run copy-assets && tsc",
    "prepublishOnly": "pnpm run build",
    "prepare": "node -e \"if (!process.env.CI) { try { require('child_process').execSync('git --version', {stdio: 'ignore'}); require('child_process').execSync('lefthook install', {stdio: 'inherit'}); } catch (e) { console.error('Lefthook installation skipped:', e.message); } }\""
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.3",
    "@floating-ui/dom": "1.6.13",
    "@onlyoffice/ai-chat": "file:onlyoffice-ai-chat-0.1.36.tgz",
    "@onlyoffice/docspace-api-sdk": "file:onlyoffice-docspace-api-sdk-3.6.0.tgz",
    "@onlyoffice/document-editor-react": "2.1.1",
    "@socket.io/component-emitter": "3.1.2",
    "@types/node": "24.10.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-text-mask": "5.4.14",
    "axios": "1.15.0",
    "classnames": "2.5.1",
    "cnbuilder": "3.1.0",
    "copy-to-clipboard": "3.3.3",
    "csvjson-json_beautifier": "5.0.4",
    "email-addresses": "3.1.0",
    "fast-deep-equal": "3.1.3",
    "framer-motion": "^12.38.0",
    "hex-rgb": "5.0.0",
    "i18next": "23.7.19",
    "katex": "^0.16.45",
    "linkify-react": "^4.3.2",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "mobx": "6.13.5",
    "mobx-react": "7.6.0",
    "react-autosize-textarea": "7.1.0",
    "react-avatar-editor": "^14.0.0",
    "react-colorful": "^5.6.1",
    "react-content-loader": "7.0.2",
    "react-countdown": "2.3.6",
    "react-device-detect": "2.2.3",
    "react-draggable": "4.4.6",
    "react-dropzone": "11.7.1",
    "react-hotkeys-hook": "3.4.7",
    "react-i18next": "14.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "7.12.0",
    "react-svg": "16.1.34",
    "react-syntax-highlighter": "^16.1.1",
    "react-text-mask": "5.5.0",
    "react-toastify": "10.0.6",
    "react-tooltip": "5.28.0",
    "react-transition-group": "4.4.5",
    "react-virtualized": "^9.22.6",
    "react-virtualized-auto-sizer": "1.0.24",
    "react-window": "1.8.10",
    "react-window-infinite-loader": "1.0.9",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "^6.0.0",
    "socket.io-client": "4.8.3",
    "styled-components": "5.3.11",
    "ts-pattern": "5.5.0",
    "xss": "^1.0.15",
    "zoom-level": "2.5.0"
  },
  "devDependencies": {
    "@babel/core": "7.25.8",
    "@biomejs/biome": "2.3.14",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-links": "^10.2.19",
    "@storybook/icons": "^2.0.1",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@svgr/rollup": "^8.1.0",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.10",
    "@types/luxon": "3.7.1",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@types/react-transition-group": "4.4.11",
    "@types/react-virtualized": "9.21.30",
    "@types/react-window": "1.8.8",
    "@types/react-window-infinite-loader": "1.0.9",
    "@types/styled-components": "5.1.34",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "@vueless/storybook-dark-mode": "^10.0.7",
    "jsdom": "^27.4.0",
    "lefthook": "^2.1.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "1.79.6",
    "serve": "14.2.5",
    "storybook": "^10.2.19",
    "typescript": "5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "4.1.0"
  },
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "docspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/DocSpace-client.git",
    "directory": "libs/ui-kit"
  },
  "files": [
    "dist",
    "locales"
  ],
  "publishConfig": {
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    ".": {
      "esm": "dist/esm/index.js",
      "cjs": "dist/cjs/index.js",
      "types": "dist/types/index.d.ts"
    }
  }
}