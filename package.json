{
  "name": "@docspace/ui-kit",
  "version": "0.0.3",
  "description": "DocSpace UI Component Library",
  "private": "true",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "storybook-build": "storybook build",
    "storybook-serve": "serve storybook-static -p 6006",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "tsc": "tsc",
    "prepublishOnly": "pnpm run build",
    "prepare": "node -e \"if (!process.env.CI) { try { require('child_process').execSync('git --version', {stdio: 'ignore'}); require('child_process').execSync('lefthook install', {stdio: 'inherit'}); } catch (e) { console.error('Lefthook installation skipped:', e.message); } }\""
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.3",
    "@floating-ui/dom": "1.6.13",
    "@types/node": "24.10.7",
    "@types/react-text-mask": "5.4.14",
    "classnames": "^2.5.1",
    "cnbuilder": "3.1.0",
    "copy-to-clipboard": "3.3.3",
    "fast-deep-equal": "3.1.3",
    "framer-motion": "^12.29.0",
    "lodash": "4.17.23",
    "react-autosize-textarea": "7.1.0",
    "csvjson-json_beautifier": "5.0.4",
    "react-draggable": "4.4.6",
    "react-svg": "16.1.34",
    "react-text-mask": "5.5.0",
    "react-tooltip": "5.28.0",
    "styled-components": "5.3.11",
    "zoom-level": "2.5.0",
    "react-toastify": "10.0.6",
    "react-device-detect": "2.2.3"
  },
  "devDependencies": {
    "@babel/core": "7.25.8",
    "@biomejs/biome": "2.3.11",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/blocks": "^8.6.15",
    "@storybook/manager-api": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@storybook/test": "^8.6.15",
    "@storybook/theming": "^8.6.15",
    "@svgr/rollup": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "4.17.10",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "5.1.34",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "jsdom": "^27.4.0",
    "lefthook": "^2.0.14",
    "postcss": "^8.4.49",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.79.5",
    "serve": "^14.2.5",
    "storybook": "^8.6.15",
    "storybook-dark-mode": "^4.0.2",
    "typescript": "^5.9.3",
    "vite": "^6.1.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.17"
  },
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "docspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/DocSpace-client.git",
    "directory": "libs/ui-kit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    ".": {
      "esm": "dist/esm/index.js",
      "cjs": "dist/cjs/index.js",
      "types": "dist/types/index.d.ts"
    }
  }
}