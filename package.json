{
  "name": "@docspace/ui-kit",
  "version": "0.0.1",
  "description": "DocSpace UI Component Library",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": "./index.ts",
    "./components": "./components/index.ts",
    "./components/*": "./components/*/index.ts",
    "./styles/*": "./styles/*",
    "./themes": "./themes/index.ts",
    "./themes/*": "./themes/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "storybook-build": "storybook build",
    "storybook-serve": "serve storybook-static -p 6006",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "tsc": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.3",
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/blocks": "^8.6.15",
    "@storybook/manager-api": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@storybook/test": "^8.6.15",
    "@storybook/theming": "^8.6.15",
    "storybook-dark-mode": "^4.0.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.17",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.79.5",
    "storybook": "^8.6.15",
    "typescript": "^5.9.3",
    "vite": "^6.1.0",
    "vitest": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "serve": "^14.2.5"
  },
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "docspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/DocSpace-client.git",
    "directory": "libs/ui-kit"
  }
}